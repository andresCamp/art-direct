---
import Layout from '../layouts/Layout.astro'
import Hero from '../components/landing/Hero.astro'
import UploadBox from '../components/landing/UploadBox.svelte'
import ExampleGallery from '../components/landing/ExampleGallery.svelte'
import StudioMount from '../components/StudioMount.svelte'
---

<Layout>
  <StudioMount client:load />

  <div id="landing" class="opacity-100 scale-100 transition-all duration-400">
    <main class="min-h-[100dvh] flex flex-col max-w-7xl mx-auto w-full px-5 md:px-10 lg:px-16 xl:px-20">
      <div class="flex flex-col md:flex-row md:items-center gap-6 md:gap-8 lg:gap-10 pt-[8vh] md:pt-[12vh] pb-[4vh] md:pb-[6vh]">
        <Hero />
        <UploadBox client:load />
      </div>
      <div class="pb-6">
        <ExampleGallery client:visible />
      </div>
    </main>
  </div>

  <div id="drag-overlay" class="drag-overlay fixed inset-0 z-50 pointer-events-none border-2 border-dashed border-art-500/20 rounded-xl m-3 hidden"></div>

  <script>
    import { store } from '../lib/store.svelte'
    import { handleFiles } from '../lib/upload'

    let dragCounter = 0
    const overlay = document.getElementById('drag-overlay')!

    document.addEventListener('dragenter', () => {
      if (store.image) return
      dragCounter++
      overlay.classList.remove('hidden')
      document.dispatchEvent(new CustomEvent('page-drag', { detail: true }))
    })

    document.addEventListener('dragleave', () => {
      dragCounter--
      if (dragCounter <= 0) {
        dragCounter = 0
        overlay.classList.add('hidden')
        document.dispatchEvent(new CustomEvent('page-drag', { detail: false }))
      }
    })

    document.addEventListener('dragover', (e) => {
      if (!store.image) e.preventDefault()
    })

    document.addEventListener('drop', (e) => {
      if (store.image) return
      e.preventDefault()
      dragCounter = 0
      overlay.classList.add('hidden')
      document.dispatchEvent(new CustomEvent('page-drag', { detail: false }))
      handleFiles(e.dataTransfer?.files ?? null)
    })
  </script>
</Layout>
